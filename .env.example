# Postgres
DATABASE_URL="postgresql://user:password@localhost:5432/tellform"

# Auth.js — generate with: npx auth secret
AUTH_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# AI provider — toggle between "openai" and "gemini" (default: openai)
AI_PROVIDER="openai"

# OpenAI — used when AI_PROVIDER=openai
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Gemini — used when AI_PROVIDER=gemini (free tier via AI Studio)
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
